# --- Database (Neon Postgres) ---
# Get this from your Neon project dashboard (or Vercel Postgres integration)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/uangku?sslmode=require"

# --- Telegram Bot ---
# Create a bot via https://t.me/BotFather, get the token with /newbot
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# Any random secret string, used to validate incoming webhook requests
TELEGRAM_WEBHOOK_SECRET="generate-a-random-secret-here"

# --- Anthropic (Claude) API ---
# Used for parsing natural-language transaction text and OCR of receipt photos
ANTHROPIC_API_KEY="sk-ant-..."

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
# Local dev: http://localhost:3000 | Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic-link sign-in (optional, only needed if you enable the Email provider)
# Any SMTP provider works, e.g. Resend SMTP, Gmail app password, Mailtrap, etc.
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="UangKu <noreply@example.com>"

# --- Vercel Blob (receipt photo storage) ---
# Created automatically when you add the Blob integration in your Vercel project
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Cron / internal endpoint protection ---
# Random secret used to authenticate Vercel Cron -> /api/cron/* calls
CRON_SECRET="generate-a-random-secret-here"

# Public app URL (used by the bot/cron to build links, and by set-webhook script)
APP_URL="https://your-app.vercel.app"
